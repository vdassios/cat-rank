# ─────────────────────────────────────────────────────────────────────────────
# Cat Ranking — runtime environment (lives at /opt/cat-ranking/.env, mode 0600)
#
# These are the variables that docker-compose.yml interpolates (`${VAR}`) and
# that the backup scripts read. Copy to `.env` on the VPS and fill in real
# values. Do NOT commit the real `.env`.
#
#   cp .env.example .env && chmod 600 .env
#
# CI-only secrets (model URL, deploy SSH, etc.) live in GitHub Actions secrets,
# NOT here — see the bottom of this file.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---------------------------------------------------------------------
# Public origin used for the CSRF Origin/Referer allowlist check. No trailing slash.
ALLOWED_ORIGIN=https://yourdomain.com

# Secret for signing the user_token cookie (HMAC). Losing this invalidates all
# existing cookies (users simply get re-issued a token). Generate a strong value:
#   openssl rand -hex 32
HMAC_SECRET=replace-with-openssl-rand-hex-32

# --- Cloudflare R2 (DB + image backups) --------------------------------------
# Used by the app entrypoint (litestream restore), the litestream sidecar,
# and the rclone backup-images sidecar.
# Create an R2 API token (Object Read & Write) scoped to the `cat-ranking` bucket.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# S3-compatible endpoint for your R2 account (no bucket in the URL).
# Find <accountid> in the Cloudflare dashboard → R2.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# --- Monitoring (healthchecks.io dead-man's-switch) --------------------------
# Daily image-backup ping (pinged by deploy/backup-images.sh on success).
HEALTHCHECK_IMAGES_URL=https://hc-ping.com/your-images-check-uuid

# Nightly restore-verify ping (pinged by deploy/verify-backup.sh on success).
HEALTHCHECK_RESTORE_URL=https://hc-ping.com/your-restore-check-uuid

# ─────────────────────────────────────────────────────────────────────────────
# NOT in this file — set these as GitHub Actions repository secrets instead:
#
#   MODEL_URL          # URL to download the MobileNetV2 ONNX model
#   MODEL_SHA256       # expected SHA-256 of the model (scripts/fetch-model.sh)
#   DEPLOY_HOST        # VPS hostname/IP for the ssh deploy step
#   DEPLOY_USER        # non-root deploy user (sudo for `docker compose`)
#   DEPLOY_SSH_KEY     # private key for the deploy user
#   GITHUB_TOKEN       # provided automatically by Actions (GHCR push)
#
# Fixed in docker-compose.yml (no need to override): NODE_ENV, HOST, PORT,
# DATABASE_PATH, UPLOAD_DIR, and the litestream LITESTREAM_* / rclone
# RCLONE_CONFIG_R2_* vars (derived from R2_* above).
# ─────────────────────────────────────────────────────────────────────────────
